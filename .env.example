# LLM 백엔드 (권장: OpenRouter — 빠르고 저렴, spend limit 설정 가능)
OPENROUTER_API_KEY=sk-or-...

# 모델 변경(선택) — 기본 deepseek/deepseek-v4-flash
# SAJU_LLM_MODEL=anthropic/claude-3.7-sonnet

# Claude 백엔드로 강제(선택) — ANTHROPIC_API_KEY 필요
# SAJU_LLM_BACKEND=claude
# ANTHROPIC_API_KEY=sk-ant-...

# 로그인 활성화(선택) — 설정하면 사주/철학 탐색이 계정별로 저장되고
# 🔗 통합 리포트와 /me 개인 보고서 페이지가 열린다.
# 생성: uv run chainlit create-secret
# CHAINLIT_AUTH_SECRET=...

# DB 경로(선택) — 기본 ./saju.db (사주 프로필·후보·철학 좌표가 한 파일에)
# SAJU_DB_PATH=./saju.db
